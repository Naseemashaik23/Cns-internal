public class SubstitutionCipher {

    static String encrypt(String text) {
        String alpha = "abcdefghijklmnopqrstuvwxyz";
        String sub   = "zyxwvutsrqponmlkjihgfedcba"; // reverse mapping
        text = text.toLowerCase();
        String result = "";

        for (int i = 0; i < text.length(); i++) {
            char ch = text.charAt(i);
            int index = alpha.indexOf(ch);
            result += (index != -1) ? sub.charAt(index) : ch;
        }
        return result;
    }

    static String decrypt(String text) {
        String alpha = "abcdefghijklmnopqrstuvwxyz";
        String sub   = "zyxwvutsrqponmlkjihgfedcba";
        String result = "";

        for (int i = 0; i < text.length(); i++) {
            char ch = text.charAt(i);
            int index = sub.indexOf(ch);
            result += (index != -1) ? alpha.charAt(index) : ch;
        }
        return result;
    }

    public static void main(String[] args) {
        String text = "HELLO";

        System.out.println("Original Text: " + text);

        String enc = encrypt(text);
        System.out.println("Encrypted Text: " + enc);

        String dec = decrypt(enc);
        System.out.println("Decrypted Text: " + dec);
    }
}

import javax.crypto.*;
import javax.crypto.spec.IvParameterSpec;
import java.security.SecureRandom;
import java.util.Base64;

public class AESShort {
    public static void main(String[] args) throws Exception {

        String text = "This is AES Symmetric Algorithm";
        System.out.println("Original Text : " + text);

        // Generate Key
        KeyGenerator kg = KeyGenerator.getInstance("AES");
        kg.init(256);
        SecretKey key = kg.generateKey();

        // Generate IV
        byte[] ivBytes = new byte[16];
        new SecureRandom().nextBytes(ivBytes);
        IvParameterSpec iv = new IvParameterSpec(ivBytes);

        System.out.println("Rijndael Key (Base64): " +
                Base64.getEncoder().encodeToString(key.getEncoded()));
        System.out.println("IV (Base64) : " +
                Base64.getEncoder().encodeToString(ivBytes));

        // Encrypt
        Cipher c = Cipher.getInstance("AES/CBC/PKCS5Padding");
        c.init(Cipher.ENCRYPT_MODE, key, iv);
        String enc = Base64.getEncoder().encodeToString(c.doFinal(text.getBytes()));

        System.out.println("Encrypted Text : " + enc);

        // Decrypt
        c.init(Cipher.DECRYPT_MODE, key, iv);
        String dec = new String(c.doFinal(Base64.getDecoder().decode(enc)));

        System.out.println("Decrypted Text : " + dec);
    }
}
